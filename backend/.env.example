# TransitOps Backend — Environment Variables
# Copy this file to .env and fill in production values

# Django Core
DJANGO_SECRET_KEY=your-production-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional — defaults to SQLite for dev)
# DATABASE_URL=postgres://user:pass@localhost:5432/transitops
